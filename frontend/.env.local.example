# Copy this file to `.env.local` (same directory) and point it at your Django API.
#
# NEXT_PUBLIC_API_URL:
# - Base URL for the Django API that the Next.js frontend will call.
# - This must include the `/api` prefix used by the Django REST endpoints.
# - Local dev example (Django on port 8000): http://localhost:8000/api
# - Production example: https://api.mydomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
