# Copy this file to `.env` (same directory) and adjust values as needed.
#
# SECRET_KEY:
# - Django secret key used for cryptographic signing.
# - Use any value for local development.
# - In production, generate a long random string and keep it secret.
#
# DEBUG:
# - True for local development.
# - MUST be False in production/staging.
#
# ALLOWED_HOSTS:
# - Comma-separated list of host/domain names this backend will serve.
# - Example for production: mysite.com,www.mysite.com
# - For local dev you can keep localhost and 127.0.0.1.
#
# CORS_ORIGINS:
# - Comma-separated list of frontend origins allowed to call this API from the browser.
# - For local dev, this should be your Next.js dev server URL.
# - Example: http://localhost:3000
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000
